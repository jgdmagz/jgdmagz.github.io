---
// StudentFlow brand mark — the FlowLogo "coin": an indigo gradient circle with
// a soft rim, carrying three white "water" waves (middle wave widest).
//
// Ported 1:1 from FlowLogo / FlowMark in the app's FlowDesign.swift (the brand
// source of truth) so the web mark matches the app and the app icon exactly:
//   • coin gradient: #8F90ED → #595BCD → #4D4EBE, top-left → bottom-right
//   • rim: white 0.35 (top) → black 0.10 (bottom), 1.2% width
//   • waves: 3 in-phase sine rows at y = 0.335 / 0.50 / 0.665, amp 5.2%,
//     stroke 8.2%, round caps; outer two at 0.96 opacity
const { size = 32, gradId = "flow" } = Astro.props;
const coinId = `${gradId}-coin`;
const rimId = `${gradId}-rim`;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 100 100"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <linearGradient id={coinId} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#8F90ED" />
      <stop offset="0.5" stop-color="#595BCD" />
      <stop offset="1" stop-color="#4D4EBE" />
    </linearGradient>
    <linearGradient id={rimId} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#FFFFFF" stop-opacity="0.35" />
      <stop offset="1" stop-color="#000000" stop-opacity="0.10" />
    </linearGradient>
  </defs>

  <!-- coin -->
  <circle cx="50" cy="50" r="50" fill={`url(#${coinId})`} />
  <!-- soft rim: lighter at top, darker at bottom -->
  <circle cx="50" cy="50" r="49.4" fill="none" stroke={`url(#${rimId})`} stroke-width="1.2" />

  <!-- three white waves (middle widest) -->
  <g
    fill="none"
    stroke="#FFFFFF"
    stroke-width="8.2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M20 33.5 Q35 23.1 50 33.5 Q65 43.9 80 33.5" opacity="0.96" />
    <path d="M15.5 50 Q32.75 39.6 50 50 Q67.25 60.4 84.5 50" opacity="1" />
    <path d="M20 66.5 Q35 56.1 50 66.5 Q65 76.9 80 66.5" opacity="0.96" />
  </g>
</svg>
