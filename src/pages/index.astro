    padding: clamp(1.8rem, 4vw, 3rem);
    border-radius: 32px;
    background:
      radial-gradient(120% 160% at 85% 10%, rgba(207, 209, 246, 0.55) 0%, transparent 55%),
      radial-gradient(120% 160% at 10% 95%, rgba(224, 241, 232, 0.5) 0%, transparent 55%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.75), #fff);
    border: 1px solid rgba(76, 78, 190, 0.12);
    box-shadow: 0 30px 70px -38px rgba(40, 36, 110, 0.45);
    overflow: hidden;
  }
  .web-copy h2 {
    margin: 0.9rem 0 0.7rem;
    font-size: clamp(1.7rem, 3.4vw, 2.3rem);
