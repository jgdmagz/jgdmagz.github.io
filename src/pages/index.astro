---
import BaseLayout from '../layouts/BaseLayout.astro';
import FlowMark from '../components/FlowMark.astro';

const features = [
  {
    title: 'Academic dashboard',
    body: 'Every course, grade, and deadline at a glance — organized by term.',
    color: 'var(--accent)',
    soon: false,
  },
  {
    title: 'GPA tracking',
    body: 'Always know exactly where you stand, course by course.',
    color: 'var(--mint)',
    soon: false,
  },
  {
    title: 'Assignments & study',
    body: 'Turn your to-dos into focused, satisfying study sessions.',
    color: 'var(--amber)',
    soon: false,
  },
  {
    title: 'Living Flow design',
    body: 'A calm, mesmerizing interface that makes studying feel good.',
    color: 'var(--lavender)',
    soon: false,
  },
  {
    title: 'GPA calculator & degree progress',
    body: 'Plan the grades you need and watch your degree fill in.',
    color: 'var(--coral)',
    soon: true,
  },
  {
    title: 'Canvas sync',
    body: 'Bring your Canvas courses and assignments in automatically.',
    color: 'var(--accent-deep)',
    soon: true,
  },
];
---

<BaseLayout
  title="StudentFlow — Your semester, in flow"
  description="StudentFlow brings your courses, assignments, and GPA into one calm, beautiful place — so you can focus on the work, not the chaos."
>
  <!-- ───────────────── Hero ───────────────── -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <canvas class="matrix"></canvas>
      <div class="glow"></div>
      <div class="glow-core"></div>
    </div>

    <div class="hero-inner">
      <div class="hero-mark"><FlowMark size={78} gradId="fgHero" /></div>
      <h1>Your semester,<br /><span class="grad-text">in flow.</span></h1>
      <p class="lede">
        StudentFlow brings your courses, assignments, and GPA into one calm, beautiful place —
        so you can focus on the work, not the chaos.
      </p>

      <div class="cta" id="get">
        <!-- TODO: replace "#" with your App Store link once the app is live -->
        <a href="#" class="btn btn-lg">Coming to the App Store</a>
        <a href="/blog" class="btn btn-ghost btn-lg">Read the latest →</a>
      </div>

      <!-- TODO: drop your hero video / app screenshot in here when it's ready -->
      <div class="hero-media" aria-hidden="true">
        <div class="media-placeholder">App preview coming soon</div>
      </div>
    </div>
  </section>

  <!-- ───────────────── Features ───────────────── -->
  <section class="section" id="features">
    <h2 class="section-title reveal">Everything school, in one calm place</h2>
    <p class="section-sub reveal" style="--reveal-delay: 0.08s">
      No more juggling tabs, sticky notes, and half-finished spreadsheets. Just your studies, organized.
    </p>

    <div class="features">
      {
        features.map((f, i) => (
          <article class="card reveal reveal-scale" style={`--card-accent:${f.color}; --reveal-delay:${i * 0.07}s`}>
            {f.soon && <span class="pill">Soon</span>}
            <div class="card-dot" />
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ───────────────── Closing CTA ───────────────── -->
  <section class="section cta-band reveal reveal-scale">
    <h2>Find your flow this semester.</h2>
    <p>Be the first to know when StudentFlow lands — and follow along as we build it.</p>
    <!-- TODO: replace "#" with your App Store link once the app is live -->
    <a href="#" class="btn btn-lg">Coming to the App Store</a>
  </section>
</BaseLayout>

<script>
  // Endless Flow matrix — a dot grid with a sine wave rippling out from the centre.
  // Paused on Reduce Motion and when the tab is hidden (battery), like the app.
  const canvas = document.querySelector('canvas.matrix');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const GAP = 28;
    const RGB = '89, 91, 205';
    let w = 0, h = 0, dots = [], raf = 0, startT = 0, rz;

    function build() {
      const rect = canvas.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = rect.width;
      h = rect.height;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.fillStyle = `rgb(${RGB})`;
      dots = [];
      for (let y = GAP / 2; y < h; y += GAP) {
        for (let x = GAP / 2; x < w; x += GAP) dots.push([x, y]);
      }
    }

    function drawStatic() {
      ctx.clearRect(0, 0, w, h);
      ctx.globalAlpha = 0.16;
      for (let i = 0; i < dots.length; i++) {
        ctx.beginPath();
        ctx.arc(dots[i][0], dots[i][1], 1.4, 0, 6.2832);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
    }

    function draw(time) {
      const cx = w / 2;
      const cy = h * 0.42;
      ctx.clearRect(0, 0, w, h);
      for (let i = 0; i < dots.length; i++) {
        const x = dots[i][0];
        const y = dots[i][1];
        const dx = x - cx;
        const dy = y - cy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const m = (Math.sin(dist * 0.021 - time * 1.7) + 1) / 2;
        ctx.globalAlpha = 0.05 + m * 0.22;
        ctx.beginPath();
        ctx.arc(x, y, 0.8 + m * 1.8, 0, 6.2832);
        ctx.fill();
      }
      ctx.globalAlpha = 1;
    }

    function loop(t) {
      if (!startT) startT = t;
      draw((t - startT) / 1000);
      raf = requestAnimationFrame(loop);
    }
    function play() {
      if (!raf) raf = requestAnimationFrame(loop);
    }
    function pause() {
      cancelAnimationFrame(raf);
      raf = 0;
    }

    build();
    if (reduce) {
      drawStatic();
    } else {
      play();
      document.addEventListener('visibilitychange', () => (document.hidden ? pause() : play()));
    }
    window.addEventListener('resize', () => {
      clearTimeout(rz);
      rz = setTimeout(() => {
        build();
        if (reduce) drawStatic();
      }, 150);
    });
  }

  // Hero background parallax — the glow + matrix drift slower than the page,
  // giving a subtle sense of depth. Skipped under Reduce Motion.
  const heroBg = document.querySelector('.hero-bg');
  if (heroBg && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let pTick = false;
    addEventListener(
      'scroll',
      () => {
        if (pTick) return;
        pTick = true;
        requestAnimationFrame(() => {
          heroBg.style.transform = `translateY(${window.scrollY * 0.28}px)`;
          pTick = false;
        });
      },
      { passive: true }
    );
  }
</script>
