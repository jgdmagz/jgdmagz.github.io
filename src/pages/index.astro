    color: var(--ink-subtle);
    font-size: 0.85rem;
    font-weight: 600;
  }

  /* Mini browser mock */
  .web-mock {
    display: block;
    text-decoration: none;
    background: #fff;
    border: 1px solid rgba(27, 28, 46, 0.08);
    border-radius: 18px;
    box-shadow: 0 30px 60px -28px rgba(40, 36, 110, 0.5);
    overflow: hidden;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
  }
  .web-mock:hover {
    transform: translateY(-5px) rotate(-0.4deg);
    box-shadow: 0 42px 80px -32px rgba(40, 36, 110, 0.6);
  }
  .wm-chrome {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 9px 12px;
    background: var(--canvas-deep);
    border-bottom: 1px solid rgba(27, 28, 46, 0.06);
  }
  .wm-chrome i {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: rgba(27, 28, 46, 0.14);
  }
  .wm-url {
    flex: 1;
    margin-left: 8px;
    font-size: 0.66rem;
    font-weight: 700;
    color: var(--ink-subtle);
    background: #fff;
    border-radius: 999px;
    padding: 4px 11px;
    letter-spacing: 0.01em;
  }
  .wm-body {
    display: flex;
    min-height: 212px;
    background: var(--canvas);
  }
  .wm-side {
