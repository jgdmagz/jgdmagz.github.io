---
import BaseLayout from '../layouts/BaseLayout.astro';
import FlowMark from '../components/FlowMark.astro';
---

<BaseLayout
  title="Your account · StudentFlow"
  description="Manage your StudentFlow profile — name, photo, school and degree. The same account syncs with the app."
>
  <section class="auth">
    <div class="auth-bg" aria-hidden="true">
      <div class="glow"></div>
      <div class="glow-core"></div>
    </div>

    <div class="auth-card card">
      <div class="auth-mark"><FlowMark size={50} gradId="fgAccount" /></div>

      <!-- Signed-out gate -->
      <div id="gate" hidden>
        <h1>Your <span class="grad-text">account</span></h1>
        <p class="auth-sub">Sign in to manage your profile.</p>
        <a href="/login" class="apple-btn" role="button">Sign in</a>
      </div>

      <!-- Signed-in profile editor -->
      <div id="account" hidden>
        <h1>Your <span class="grad-text">profile</span></h1>
        <p class="auth-sub">Signed in as <strong id="email"></strong></p>

        <label class="avatar" for="avatar-input" title="Change photo">
          <img id="avatar-img" alt="Your avatar" hidden />
          <span id="avatar-fallback" class="avatar-fallback" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="34" height="34" fill="currentColor">
              <path d="M12 12a5 5 0 1 0 0-10 5 5 0 0 0 0 10Zm0 2c-5 0-9 2.5-9 6v2h18v-2c0-3.5-4-6-9-6Z"/>
            </svg>
          </span>
          <span class="avatar-edit">
            <svg viewBox="0 0 24 24" width="13" height="13" fill="currentColor">
              <path d="M4 17.25V20h2.75L17.8 8.94l-2.75-2.75L4 17.25ZM20.7 7a1 1 0 0 0 0-1.41l-2.34-2.34a1 1 0 0 0-1.41 0l-1.6 1.6 3.75 3.75L20.7 7Z"/>
            </svg>
          </span>
        </label>
        <input id="avatar-input" type="file" accept="image/*" hidden />
        <p class="avatar-hint">Tap the photo to change it</p>

        <div class="field">
          <label for="name">NAME</label>
          <input id="name" type="text" autocomplete="name" placeholder="Your name" />
        </div>
        <div class="field">
          <label for="school">SCHOOL</label>
          <input id="school" type="text" placeholder="e.g. UC Berkeley" />
        </div>
        <div class="field">
          <label for="degree">DEGREE / PROGRAM</label>
          <input id="degree" type="text" placeholder="e.g. B.S. Computer Science" />
        </div>
        <div class="field field-readonly">
          <label>CURRENT TERM</label>
          <div id="term" class="term-value">Set in the app</div>
        </div>

        <button id="save" class="apple-btn" type="button">Save changes</button>
        <p id="status" class="auth-status" hidden></p>

        <p class="auth-fine">
          Your name, photo, school and degree sync with the StudentFlow app.
          Your term is set in the app's planner.
        </p>
        <button id="signout" class="btn btn-ghost signout" type="button">Sign out</button>
      </div>
    </div>
  </section>

  <!--
    is:inline keeps Astro from bundling this so the browser loads supabase-js
    from the CDN (no npm install needed). The anon key is public by design —
    real access is gated by Supabase Row-Level-Security, not this key.
  -->
  <script is:inline type="module">
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

    const supabase = createClient(
      'https://jatxquhxqxrnjbmjoqna.supabase.co',
      'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImphdHhxdWh4cXhybmpibWpvcW5hIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA2MTAyMTksImV4cCI6MjA5NjE4NjIxOX0.cx2qMXzadunoJtq82FT-UYAstFZ_ym3FAnIpHkzgzdM'
    );

    const $ = (id) => document.getElementById(id);
    let user = null;
    let pendingAvatar = null;

    function setStatus(msg, isError = false) {
      const el = $('status');
      el.hidden = false;
      el.textContent = msg;
      el.classList.toggle('ok', !isError);
    }

    function renderAvatar(url) {
      if (url) {
        $('avatar-img').src = url;
        $('avatar-img').hidden = false;
        $('avatar-fallback').hidden = true;
      } else {
        $('avatar-img').hidden = true;
        $('avatar-fallback').hidden = false;
      }
    }

    function renderTerm(p) {
      const bits = [p.term_label, p.term_system].filter(Boolean);
      $('term').textContent = bits.length ? bits.join(' · ') : 'Set in the app';
    }

    async function loadProfile() {
      const { data } = await supabase
        .from('profiles')
        .select('*')
        .eq('id', user.id)
        .single();
      const p = data ?? {};
      $('name').value = p.display_name ?? '';
      $('school').value = p.school ?? '';
      $('degree').value = p.degree ?? '';
      renderTerm(p);
      renderAvatar(p.avatar_url);
    }

    async function init() {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        $('gate').hidden = false;
        $('account').hidden = true;
        return;
      }
      user = session.user;
      $('gate').hidden = true;
      $('account').hidden = false;
      $('email').textContent = user.email ?? user.id;
      await loadProfile();
    }

    $('avatar-input').addEventListener('change', async (e) => {
      const file = e.target.files[0];
      if (!file || !user) return;
      setStatus('Uploading photo…');
      const path = `${user.id}/avatar.jpg`;
      const { error } = await supabase.storage
        .from('avatars')
        .upload(path, file, { contentType: file.type || 'image/jpeg', upsert: true });
      if (error) { setStatus(error.message, true); return; }
      const { data } = supabase.storage.from('avatars').getPublicUrl(path);
      pendingAvatar = `${data.publicUrl}?v=${Date.now()}`;
      renderAvatar(pendingAvatar);
      setStatus('Photo updated — Save to keep it.');
    });

    $('save').addEventListener('click', async () => {
      if (!user) return;
      setStatus('Saving…');
      // Only the web-editable fields — term_* stays app-owned and is left
      // untouched by this partial upsert.
      const row = {
        id: user.id,
        display_name: $('name').value.trim() || null,
        school: $('school').value.trim() || null,
        degree: $('degree').value.trim() || null,
      };
      if (pendingAvatar) row.avatar_url = pendingAvatar;
      const { error } = await supabase.from('profiles').upsert(row);
      if (error) { setStatus(error.message, true); return; }
      pendingAvatar = null;
      setStatus('Saved ✓');
    });

    $('signout').addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/login';
    });

    supabase.auth.onAuthStateChange(() => init());
    init();
  </script>
</BaseLayout>

<style>
  .auth {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 150px);
    padding: 2.5rem 1rem;
    overflow: hidden;
  }
  .auth-bg { position: absolute; inset: 0; z-index: 0; }
  .auth-card {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 420px;
    text-align: center;
    padding: 2.4rem 2rem;
    background: rgba(255, 255, 255, 0.86);
    -webkit-backdrop-filter: saturate(160%) blur(10px);
    backdrop-filter: saturate(160%) blur(10px);
    box-shadow: 0 30px 60px -32px rgba(76, 78, 190, 0.45);
    animation: fadeUp 0.7s ease both;
  }
  .auth-mark { display: flex; justify-content: center; margin-bottom: 1rem; }
  .auth-card h1 {
    font-size: 1.7rem;
    letter-spacing: -0.02em;
    font-weight: 800;
    margin: 0 0 0.5rem;
  }
  .auth-sub { color: var(--ink-mid); margin: 0 0 1.5rem; font-size: 1rem; }

  /* Avatar */
  .avatar {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 96px;
    height: 96px;
    border-radius: 999px;
    cursor: pointer;
    background: linear-gradient(135deg, #6466e6, #4c4eb0);
    color: rgba(255, 255, 255, 0.92);
    overflow: visible;
    box-shadow: 0 14px 28px -14px rgba(76, 78, 190, 0.55);
  }
  .avatar img,
  .avatar-fallback {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 999px;
    object-fit: cover;
  }
  .avatar-fallback { display: flex; align-items: center; justify-content: center; }
  .avatar-edit {
    position: absolute;
    right: -2px;
    bottom: -2px;
    width: 30px;
    height: 30px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent, #595bcd);
    color: #fff;
    border: 2px solid #fff;
  }
  .avatar-hint { color: var(--ink-subtle); font-size: 0.8rem; margin: 0.6rem 0 1.4rem; }

  /* Fields */
  .field { text-align: left; margin-bottom: 0.9rem; }
  .field label {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--ink-subtle);
    margin: 0 0 0.35rem 0.2rem;
  }
  .field input {
    width: 100%;
    box-sizing: border-box;
    font-family: var(--font);
    font-size: 1rem;
    color: var(--ink);
    padding: 0.8rem 1rem;
    border: 1px solid rgba(76, 78, 190, 0.18);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.7);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .field input:focus {
    outline: none;
    border-color: var(--accent, #595bcd);
    box-shadow: 0 0 0 3px rgba(89, 91, 205, 0.14);
  }
  .field-readonly .term-value {
    padding: 0.8rem 1rem;
    border-radius: 14px;
    background: rgba(76, 78, 190, 0.06);
    color: var(--ink-mid);
    font-size: 0.95rem;
  }

  .apple-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    width: 100%;
    border: none;
    cursor: pointer;
    background: #000;
    color: #fff;
    font-family: var(--font);
    font-weight: 600;
    font-size: 1.05rem;
    padding: 0.9rem 1.3rem;
    border-radius: 999px;
    margin-top: 0.6rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .apple-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 28px -12px rgba(0, 0, 0, 0.4);
  }
  .auth-fine { color: var(--ink-subtle); font-size: 0.82rem; margin: 1.1rem 0 0.4rem; }
  .signout { margin-top: 0.4rem; }
  .auth-status { color: var(--coral); font-size: 0.9rem; margin-top: 0.9rem; }
  .auth-status.ok { color: #2e9b6b; }
</style>
