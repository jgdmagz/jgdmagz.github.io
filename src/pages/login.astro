---
import BaseLayout from '../layouts/BaseLayout.astro';
import FlowMark from '../components/FlowMark.astro';
---

<BaseLayout
  title="Sign in · StudentFlow"
  description="Sign in to StudentFlow with your Apple ID — the same account works in the app and on the web."
>
  <section class="auth">
    <div class="auth-bg" aria-hidden="true">
      <div class="glow"></div>
      <div class="glow-core"></div>
    </div>

    <div class="auth-card card">
      <div class="auth-mark"><FlowMark size={58} gradId="fgAuth" /></div>

      <div id="signed-out">
        <h1>Welcome to <span class="grad-text">StudentFlow</span></h1>
        <p class="auth-sub">Sign in with your Apple ID — the same account works in the app and here.</p>

        <button id="apple" class="apple-btn" type="button">
          <svg viewBox="0 0 384 512" width="17" height="17" fill="currentColor" aria-hidden="true">
            <path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C71.5 141.2 16 184.6 16 273.5c0 26.6 4.9 54.1 14.6 82.4 13 37.1 59.9 128.1 108.8 126.6 25.6-.6 43.7-18.2 77-18.2 32.3 0 49 18.2 77.4 18.2 49.3-.7 91.7-83.4 104.1-120.6-66.2-31.2-66.2-91.4-66.2-93.2zM254.8 90.9c30.8-36.5 28-69.7 27.1-81.6-27.2 1.6-58.7 18.5-76.6 39.4-19.7 22.6-31.3 50.5-28.8 81.4 29.4 2.3 56.2-12.8 78.3-39.2z"></path>
          </svg>
          Sign in with Apple
        </button>

        <p class="auth-fine">
          We only use your Apple ID to sign you in — nothing else. See our
          <a href="/privacy">privacy policy</a>.
        </p>
      </div>

      <div id="signed-in" hidden>
        <h1>You're in 🎉</h1>
        <p class="auth-sub">Signed in as <strong id="who"></strong></p>
        <a href="/account" class="apple-btn" role="button">Manage your account</a>
        <button id="signout" class="btn btn-ghost" type="button" style="margin-top:0.7rem">Sign out</button>
      </div>

      <p id="status" class="auth-status" hidden></p>
    </div>
  </section>

  <!--
    is:inline keeps Astro from bundling this so the browser loads supabase-js
    from the CDN (no npm install needed). The anon key is public by design —
    real access is gated by Supabase Row-Level-Security, not this key.
  -->
  <script is:inline type="module">
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

    const supabase = createClient(
      'https://jatxquhxqxrnjbmjoqna.supabase.co',
      'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImphdHhxdWh4cXhybmpibWpvcW5hIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA2MTAyMTksImV4cCI6MjA5NjE4NjIxOX0.cx2qMXzadunoJtq82FT-UYAstFZ_ym3FAnIpHkzgzdM'
    );

    const $ = (id) => document.getElementById(id);

    async function render() {
      const { data: { session } } = await supabase.auth.getSession();
      const signedIn = !!session;
      $('signed-out').hidden = signedIn;
      $('signed-in').hidden = !signedIn;
      if (signedIn) $('who').textContent = session.user.email ?? session.user.id;
    }

    $('apple').addEventListener('click', async () => {
      $('status').hidden = true;
      const { error } = await supabase.auth.signInWithOAuth({
        provider: 'apple',
        options: { redirectTo: window.location.origin + window.location.pathname },
      });
      if (error) { $('status').hidden = false; $('status').textContent = error.message; }
    });

    $('signout').addEventListener('click', async () => { await supabase.auth.signOut(); render(); });

    supabase.auth.onAuthStateChange(() => render());
    render();
  </script>
</BaseLayout>

<style>
  .auth {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 150px);
    padding: 2.5rem 1rem;
    overflow: hidden;
  }
  .auth-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .auth-card {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 400px;
    text-align: center;
    padding: 2.6rem 2rem;
    background: rgba(255, 255, 255, 0.86);
    -webkit-backdrop-filter: saturate(160%) blur(10px);
    backdrop-filter: saturate(160%) blur(10px);
    box-shadow: 0 30px 60px -32px rgba(76, 78, 190, 0.45);
    animation: fadeUp 0.7s ease both;
  }
  .auth-mark {
    display: flex;
    justify-content: center;
    margin-bottom: 1.25rem;
  }
  .auth-card h1 {
    font-size: 1.7rem;
    letter-spacing: -0.02em;
    font-weight: 800;
    margin: 0 0 0.5rem;
  }
  .auth-sub {
    color: var(--ink-mid);
    margin: 0 0 1.7rem;
    font-size: 1rem;
  }
  .apple-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    width: 100%;
    border: none;
    cursor: pointer;
    background: #000;
    color: #fff;
    font-family: var(--font);
    font-weight: 600;
    font-size: 1.05rem;
    padding: 0.9rem 1.3rem;
    border-radius: 999px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .apple-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 28px -12px rgba(0, 0, 0, 0.4);
  }
  .apple-btn svg {
    margin-top: -2px;
  }
  .auth-fine {
    color: var(--ink-subtle);
    font-size: 0.82rem;
    margin: 1.1rem 0 0;
  }
  .auth-status {
    color: var(--coral);
    font-size: 0.9rem;
    margin-top: 1.1rem;
  }
</style>
