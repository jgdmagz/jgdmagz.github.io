---
import '../styles/global.css';
import FlowMark from '../components/FlowMark.astro';

const {
  title = 'StudentFlow',
  description = 'StudentFlow brings your courses, assignments, and GPA into one calm, beautiful place.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#595BCD" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
    <slot name="head" />
  </head>
  <body>
    <header class="nav">
      <a href="/" class="brand">
        <FlowMark size={30} gradId="fgNav" />
        <span>StudentFlow</span>
      </a>
      <button
        class="nav-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="nav-links" id="nav-menu">
        <a href="/#features">Features</a>
        <a href="/#themes">Themes</a>
        <a href="/#install">Install</a>
        <a href="/blog">Blog</a>
        <a href="/login" id="nav-auth" class="nav-auth">Log in</a>
        <a
          href="https://testflight.apple.com/join/wjhfuk5M"
          target="_blank"
          rel="noopener"
          class="btn btn-sm">Join the beta</a
        >
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="brand">
        <FlowMark size={26} gradId="fgFoot" />
        <span>StudentFlow</span>
      </div>
      <p>© 2026 StudentFlow. Made for students, in flow.</p>
      <p class="footer-links">
        <a href="/support">Support</a>
        <span aria-hidden="true">·</span>
        <a href="/privacy">Privacy</a>
      </p>
    </footer>

    <script>
      // Mobile nav toggle — progressive enhancement; the site is fully usable without JS.
      const navToggle = document.querySelector('.nav-toggle');
      const navMenu = document.getElementById('nav-menu');
      if (navToggle && navMenu) {
        const setOpen = (open) => {
          navMenu.classList.toggle('open', open);
          navToggle.classList.toggle('is-open', open);
          navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          navToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        };
        navToggle.addEventListener('click', () => setOpen(!navMenu.classList.contains('open')));
        navMenu.querySelectorAll('a').forEach((link) =>
          link.addEventListener('click', () => setOpen(false))
        );
      }

      // Nav gains a hairline border + stronger blur once the page scrolls.
      const navEl = document.querySelector('.nav');
      if (navEl) {
        let navTick = false;
        const onScroll = () => {
          if (navTick) return;
          navTick = true;
          requestAnimationFrame(() => {
            navEl.classList.toggle('scrolled', window.scrollY > 8);
            navTick = false;
          });
        };
        addEventListener('scroll', onScroll, { passive: true });
        onScroll();
      }

      // Scroll-reveal — fade/rise elements tagged .reveal as they enter view.
      // Honors Reduce Motion (shows everything immediately, no animation).
      const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const reveals = document.querySelectorAll('.reveal');
      if (reduceMotion || !('IntersectionObserver' in window)) {
        reveals.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        reveals.forEach((el) => io.observe(el));
      }
    </script>

    <!--
      Auth-aware nav. A read-only Supabase client (no URL detection / no token
      refresh so it never fights the per-page auth client) swaps the "Log in"
      link for an account chip — avatar + first name → /account — when signed
      in. Signed-out / no-JS users just see "Log in".
    -->
    <script is:inline type="module">
      import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

      const supabase = createClient(
        'https://jatxquhxqxrnjbmjoqna.supabase.co',
        'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImphdHhxdWh4cXhybmpibWpvcW5hIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA2MTAyMTksImV4cCI6MjA5NjE4NjIxOX0.cx2qMXzadunoJtq82FT-UYAstFZ_ym3FAnIpHkzgzdM',
        { auth: { persistSession: true, autoRefreshToken: false, detectSessionInUrl: false } }
      );

      const authLink = document.getElementById('nav-auth');
      const esc = (s) =>
        String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

      async function syncNav(session) {
        if (!authLink) return;
        if (!session) {
          authLink.href = '/login';
          authLink.textContent = 'Log in';
          authLink.classList.remove('signed-in');
          return;
        }
        authLink.href = '/account';
        authLink.classList.add('signed-in');
        let name = session.user.email || 'Account';
        let avatarUrl = null;
        try {
          const { data } = await supabase
            .from('profiles')
            .select('display_name, avatar_url')
            .eq('id', session.user.id)
            .single();
          if (data) {
            name = data.display_name || name;
            avatarUrl = data.avatar_url;
          }
        } catch (_) {}
        const first = esc((name || 'Account').split('@')[0].split(' ')[0]) || 'Account';
        const initial = first.charAt(0).toUpperCase() || 'A';
        authLink.innerHTML =
          `<span class="nav-avatar">${avatarUrl ? `<img src="${esc(avatarUrl)}" alt="" />` : initial}</span>` +
          `<span>${first}</span>`;
      }

      supabase.auth.onAuthStateChange((_event, session) => syncNav(session));
      supabase.auth.getSession().then(({ data }) => syncNav(data.session)).catch(() => {});
    </script>
  </body>
</html>

<style is:global>
  .nav-auth.signed-in {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-weight: 600;
  }
  .nav-avatar {
    width: 26px;
    height: 26px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #6466e6, #4c4eb0);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    overflow: hidden;
    flex: 0 0 auto;
  }
  .nav-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
