---
import '../styles/global.css';
import FlowMark from '../components/FlowMark.astro';

const {
  title = 'StudentFlow',
  description = 'StudentFlow brings your courses, assignments, and GPA into one calm, beautiful place.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#595BCD" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <header class="nav">
      <a href="/" class="brand">
        <FlowMark size={30} gradId="fgNav" />
        <span>StudentFlow</span>
      </a>
      <button
        class="nav-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="nav-links" id="nav-menu">
        <a href="/#features">Features</a>
        <a href="/blog">Blog</a>
        <a href="/login">Log in</a>
        <a href="/#get" class="btn btn-sm">Get the app</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="brand">
        <FlowMark size={26} gradId="fgFoot" />
        <span>StudentFlow</span>
      </div>
      <p>© 2026 StudentFlow. Made for students, in flow.</p>
    </footer>

    <script>
      // Mobile nav toggle — progressive enhancement; the site is fully usable without JS.
      const navToggle = document.querySelector('.nav-toggle');
      const navMenu = document.getElementById('nav-menu');
      if (navToggle && navMenu) {
        const setOpen = (open) => {
          navMenu.classList.toggle('open', open);
          navToggle.classList.toggle('is-open', open);
          navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          navToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
        };
        navToggle.addEventListener('click', () => setOpen(!navMenu.classList.contains('open')));
        navMenu.querySelectorAll('a').forEach((link) =>
          link.addEventListener('click', () => setOpen(false))
        );
      }

      // Scroll-reveal — fade/rise elements tagged .reveal as they enter view.
      // Honors Reduce Motion (shows everything immediately, no animation).
      const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const reveals = document.querySelectorAll('.reveal');
      if (reduceMotion || !('IntersectionObserver' in window)) {
        reveals.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        reveals.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
