---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const fmt = (d) =>
  new Date(d).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${frontmatter.title} — StudentFlow`} description={frontmatter.description}>
  <article class="post">
    <a class="back" href="/blog">← All updates</a>
    <h1>{frontmatter.title}</h1>
    <p class="date">{fmt(frontmatter.pubDate)}</p>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
